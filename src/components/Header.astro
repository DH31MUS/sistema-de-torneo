---
import { siteConfig } from '../config/site';
---
<header class="sticky top-0 z-50 bg-[#0a0a0a]/80 backdrop-blur-md border-b border-[#6a0dad]/50">
  <div class="container mx-auto px-4 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-4 group">
      <div class="w-12 h-12 bg-gradient-to-br from-[#0047AB] to-[#39ff14] rounded-lg flex items-center justify-center transform group-hover:rotate-12 transition-transform shadow-[0_0_15px_rgba(57,255,20,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bot"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </div>
      <span class="text-3xl font-primary font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-[#0047AB] to-[#4a5568] drop-shadow-[0_0_8px_rgba(0,71,171,0.5)] mt-1">
        ROBOT TOURNAMENT
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8 font-bold text-sm uppercase tracking-wider">
      <a href={siteConfig.links.quienesSomos} class="hover:text-[#39ff14] transition-colors">Quiénes Somos</a>
      <a href={siteConfig.links.reglamento} target="_blank" class="hover:text-[#39ff14] transition-colors">Reglamento</a>
      <a href="/acreditaciones" class="hover:text-[#39ff14] transition-colors">Acreditaciones</a>
      <a href="/categorias" class="hover:text-[#39ff14] transition-colors">Categorías</a>
      <a href="/en-vivo" class="text-[#39ff14] hover:text-[#ffea00] hover:drop-shadow-[0_0_10px_rgba(57,255,20,0.8)] transition-all flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-[#39ff14] animate-pulse"></span>
        En Vivo
      </a>
    </nav>
  </div>
</header>
