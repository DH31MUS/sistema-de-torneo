---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { equipos, llaves } from '../db/schema';
import { siteConfig } from '../config/site';
import { eq, isNull } from 'drizzle-orm';

let message = "";
let selectedCategory = "";

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action');

    if (action === 'generate_brackets') {
      const categoryId = data.get('categoryId')?.toString();
      if (categoryId) selectedCategory = categoryId;
      
      if (categoryId) {
        // Obtener equipos
        const teams = await db.select().from(equipos).where(eq(equipos.categoriaId, categoryId));
        
        if (teams.length < 2) {
          message = `Error: Mínimo 2 equipos para generar llaves. Actuales: ${teams.length}`;
        } else {
          // Limpiar llaves anteriores de esta categoría para empezar de cero
          await db.delete(llaves).where(eq(llaves.categoriaId, categoryId));
          
          // Emparejar
          const shuffled = [...teams].sort(() => Math.random() - 0.5);
          
          if (shuffled.length % 2 !== 0) {
            const randomTeamIndex = Math.floor(Math.random() * (shuffled.length - 1));
            shuffled.push(shuffled[randomTeamIndex]);
          }

          const newMatches = [];
          
          for (let i = 0; i < shuffled.length; i += 2) {
            const team1 = shuffled[i];
            const team2 = shuffled[i + 1];
            
            newMatches.push({
              categoriaId: categoryId,
              ronda: 1,
              equipo1Id: team1.id,
              equipo2Id: team2.id,
              ganadorId: null
            });
          }
          
          await db.insert(llaves).values(newMatches);
          message = `Llaves generadas exitosamente. Se crearon ${newMatches.length} combates.`;
        }
      }
    } else if (action === 'generate_next_round') {
      const categoryId = data.get('categoryId')?.toString();
      if (categoryId) selectedCategory = categoryId;
      if (categoryId) {
        const currentMatches = await db.select().from(llaves).where(eq(llaves.categoriaId, categoryId));
        if (currentMatches.length === 0) {
          message = "Error: No hay llaves. Genera la 1ra Ronda primero.";
        } else {
          const maxRound = Math.max(...currentMatches.map(m => m.ronda));
          const lastRoundMatches = currentMatches.filter(m => m.ronda === maxRound);
          const winners = lastRoundMatches.map(m => m.ganadorId).filter(id => id !== null);
          
          if (winners.length < lastRoundMatches.length) {
            message = `Error: Faltan definir ganadores en la Ronda ${maxRound}. Asigna un ganador a todos los combates primero.`;
          } else if (winners.length === 1) {
            message = `¡El torneo ya terminó! Ya tenemos un ganador absoluto.`;
          } else {
            const newMatches = [];
            for (let i = 0; i < winners.length; i += 2) {
              const w1 = winners[i];
              const w2 = winners[i + 1];
              newMatches.push({
                categoriaId: categoryId,
                ronda: maxRound + 1,
                equipo1Id: w1,
                equipo2Id: w2 || null,
                ganadorId: w2 ? null : w1 // auto-win if odd number of winners
              });
            }
            await db.insert(llaves).values(newMatches);
            message = `¡Ronda ${maxRound + 1} generada con éxito! Se crearon ${newMatches.length} combates.`;
          }
        }
      }
    } else if (action === 'set_winner') {
      const matchId = parseInt(data.get('matchId')?.toString() || '0');
      const winnerId = parseInt(data.get('winnerId')?.toString() || '0');
      const categoryId = data.get('categoryId')?.toString();
      if (categoryId) selectedCategory = categoryId;
      
      if (matchId && winnerId) {
        await db.update(llaves).set({ ganadorId: winnerId }).where(eq(llaves.id, matchId));
        message = `Ganador establecido exitosamente para el combate ${matchId}`;
      } else {
        message = `Por favor, ingresa IDs válidos.`;
      }
    }
  } catch (error: any) {
    message = "Error del sistema: " + (error?.message || String(error));
    console.error(error);
  }
}

let pendingMatches: any[] = [];
let teamsMap: Record<number, string> = {};

try {
  pendingMatches = await db.select().from(llaves).where(isNull(llaves.ganadorId));
  const allTeams = await db.select().from(equipos);
  teamsMap = Object.fromEntries(allTeams.map(t => [t.id, t.name]));
} catch(e) {
  // Ignorar errores si la DB aún no está lista
}
---
<Layout title="Dashboard de Administración">
  <section class="py-20 min-h-screen bg-[#050505]">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="bg-[#111] border-2 border-[#0047AB] p-8 rounded-sm shadow-[0_0_40px_rgba(106,13,173,0.3)]">
        <h1 class="text-4xl font-black text-center mb-8 uppercase tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-[#0047AB] to-[#39ff14]">
          Panel de Control <br/><span class="text-2xl text-white drop-shadow-none">ROBOT TOURNAMENT</span>
        </h1>

        {message && (
          <div class="p-4 mb-8 bg-[#39ff14]/10 border border-[#39ff14] text-[#39ff14] font-bold rounded-sm">
            {message}
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Generar Llaves -->
          <div class="p-6 bg-[#1a1a1a] rounded border border-[#0047AB]/30 hover:border-[#0047AB] transition-colors md:col-span-2">
          <h2 class="text-2xl font-bold text-[#0047AB] mb-4 uppercase tracking-widest">Generar Combates</h2>
          <p class="text-sm text-gray-400 mb-4">Selecciona una categoría para generar sus llaves o avanzar de ronda. "Generar 1ra Ronda" borrará las llaves actuales de esa categoría.</p>
          <form method="POST" class="flex flex-col gap-4">
            <select name="categoryId" class="p-3 bg-[#0a0a0a] border border-[#0047AB] text-white rounded outline-none focus:border-[#39ff14]">
              {siteConfig.categorias.map(cat => (
                <option value={cat.id} selected={cat.id === selectedCategory}>{cat.name}</option>
              ))}
            </select>
            <div class="flex flex-col sm:flex-row gap-4">
              <button type="submit" name="action" value="generate_brackets" class="flex-1 bg-[#0047AB] text-white font-black p-3 rounded uppercase hover:bg-[#0047AB] transition-colors tracking-widest">
                Generar 1ra Ronda
              </button>
              <button type="submit" name="action" value="generate_next_round" class="flex-1 bg-[#39ff14] text-black font-black p-3 rounded uppercase hover:bg-[#ffea00] transition-colors tracking-widest">
                Avanzar a Siguiente Ronda
              </button>
            </div>
          </form>
        </div>

          <!-- Marcar Ganador Automático -->
          <div class="bg-[#0a0a0a] p-6 border border-gray-800 rounded-sm hover:border-[#39ff14]/50 transition-colors md:col-span-2">
            <h2 class="text-xl font-bold mb-4 text-[#39ff14] uppercase tracking-widest">2. Combates Pendientes</h2>
            <p class="text-sm text-gray-400 mb-6">Haz clic en el robot ganador para avanzarlo automáticamente de ronda.</p>
            
            <p id="empty-matches-msg" class="text-gray-500 text-sm font-bold bg-[#111] p-4 rounded text-center border border-gray-800" style="display: none;">
               No hay combates pendientes por definir en esta categoría.
             </p>
             
             <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="matches-grid">
               {pendingMatches.map((match, index) => (
                 <div class="match-card border border-gray-700 p-4 rounded bg-[#111] hover:border-[#39ff14]/30 transition-colors" data-category={match.categoriaId}>
                     <div class="text-xs text-[#0047AB] font-bold mb-3 uppercase tracking-widest">
                       Ronda {match.ronda} | Cat: {match.categoriaId} <span class="text-gray-600 ml-2">Combate #{index + 1}</span>
                     </div>
                     <form method="POST" class="flex flex-col gap-2">
                       <input type="hidden" name="action" value="set_winner" />
                       <input type="hidden" name="matchId" value={match.id} />
                       <input type="hidden" name="categoryId" value={match.categoriaId} />
                       
                       <div class="flex items-stretch gap-2 h-14">
                         {match.equipo1Id && (
                           <button type="submit" name="winnerId" value={match.equipo1Id} class="flex-1 bg-gray-800 hover:bg-[#39ff14] hover:text-black text-gray-300 rounded transition-colors text-sm font-bold break-all px-2 shadow-[0_0_10px_rgba(0,0,0,0.5)]">
                             {teamsMap[match.equipo1Id] || 'Equipo 1'}
                           </button>
                         )}
                         <div class="flex items-center justify-center px-1 text-gray-600 text-xs font-black">VS</div>
                         {match.equipo2Id && (
                           <button type="submit" name="winnerId" value={match.equipo2Id} class="flex-1 bg-gray-800 hover:bg-[#39ff14] hover:text-black text-gray-300 rounded transition-colors text-sm font-bold break-all px-2 shadow-[0_0_10px_rgba(0,0,0,0.5)]">
                             {teamsMap[match.equipo2Id] || 'Equipo 2'}
                           </button>
                         )}
                       </div>
                     </form>
                   </div>
                 ))}
               </div>
          </div>
        </div>

        <div class="mt-8 p-6 bg-[#0a0a0a] border border-gray-800 rounded-sm">
          <h2 class="text-sm font-bold mb-4 text-gray-300 uppercase tracking-widest">Instrucciones</h2>
          <ul class="list-disc pl-5 text-gray-500 space-y-2 text-sm font-light">
            <li>Selecciona una categoría y haz clic en <strong class="text-white">Generar 1ra Ronda</strong>.</li>
            <li>En la sección de "Combates Pendientes", simplemente <strong class="text-[#39ff14]">haz clic sobre el nombre del robot que ganó</strong> la batalla.</li>
            <li>Una vez que todos los combates de la ronda tengan un ganador, usa el botón <strong class="text-[#ffea00]">Avanzar a Siguiente Ronda</strong> para crear automáticamente las llaves de la siguiente etapa.</li>
          </ul>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const select = document.querySelector('select[name="categoryId"]');
    const matchCards = document.querySelectorAll('.match-card');
    const emptyMsg = document.getElementById('empty-matches-msg');

    function filterMatches() {
      if (!select) return;
      const selectedCategory = select.value;
      let hasVisibleMatches = false;

      matchCards.forEach(card => {
        if (card.dataset.category === selectedCategory) {
          card.style.display = 'block';
          hasVisibleMatches = true;
        } else {
          card.style.display = 'none';
        }
      });

      if (emptyMsg) {
        emptyMsg.style.display = hasVisibleMatches ? 'none' : 'block';
      }
    }

    if (select) {
      select.addEventListener('change', filterMatches);
      filterMatches();
    }
  });
</script>
