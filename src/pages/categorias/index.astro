---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config/site';
---
<Layout title="Categorías">
  <section class="py-24 min-h-[80vh] relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] to-[#1a0033] z-[-1]"></div>
    <div class="container mx-auto px-4">
      <h1 class="text-5xl md:text-7xl font-black mb-16 text-center uppercase tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-[#39ff14] to-[#ffea00]">
        Categorías de Combate
      </h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {siteConfig.categorias.map(cat => (
          <a href={`/llaves/${cat.id}`} class="group relative block h-64 bg-[#111] overflow-hidden border border-[#6a0dad]/30 hover:border-[#39ff14] transition-all">
            <div class="absolute inset-0 bg-black/60 group-hover:bg-black/20 transition-all z-10"></div>
            <!-- Background pattern -->
            <div class="absolute inset-0 opacity-20 bg-[radial-gradient(#6a0dad_1px,transparent_1px)] [background-size:16px_16px]"></div>
            
            <div class="relative z-20 h-full flex flex-col items-center justify-center p-6 text-center">
              <h2 class="text-3xl font-black uppercase tracking-wider text-white group-hover:text-[#39ff14] transition-colors drop-shadow-md">
                {cat.name}
              </h2>
              <span class="mt-4 px-4 py-2 border border-[#9d4edd] text-[#9d4edd] group-hover:bg-[#9d4edd] group-hover:text-white font-bold tracking-widest text-sm transition-all">
                VER LLAVES
              </span>
            </div>
            
            <div class="absolute bottom-0 left-0 h-1 bg-gradient-to-r from-[#6a0dad] to-[#39ff14] w-0 group-hover:w-full transition-all duration-500"></div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
