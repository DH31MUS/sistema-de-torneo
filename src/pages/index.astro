---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';

// Merch disponible
const merchItems = [
  { id: 1, name: "PLAYERA BÁSICA", price: "$200 MXN", image: "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" },
  { id: 2, name: "EDICIÓN COMPETIDOR", price: "$250 MXN", image: "https://images.unsplash.com/photo-1581655353564-df123a1eb820?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" },
  { id: 3, name: "SUDADERA OFICIAL", price: "$450 MXN", image: "https://images.unsplash.com/photo-1556821840-3a63f95609a7?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=60" },
];
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0a0a0a] z-10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#0047AB]/20 rounded-full blur-[120px] pointer-events-none"></div>
    
    <div class="container mx-auto px-4 relative z-20 text-center">
      <div class="mb-8 flex justify-center">
        <h1 class="text-6xl md:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-br from-[#0047AB] to-[#39ff14] drop-shadow-[0_0_20px_rgba(0,71,171,0.8)] uppercase tracking-tighter">
          ROBOT<br/>TOURNAMENT
        </h1>
      </div>
      <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto font-light">
        El evento de robótica competitiva más espectacular. Prepara tu robot, entra a la arena y destruye a tus rivales.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <a href="/categorias" class="px-8 py-4 bg-[#39ff14] text-black font-black text-lg uppercase tracking-widest hover:bg-[#ffea00] hover:scale-105 transition-all shadow-[0_0_20px_rgba(57,255,20,0.4)]">
          Ver Categorías
        </a>
        <a href={siteConfig.links.reglamento} target="_blank" class="px-8 py-4 bg-transparent border-2 border-[#0047AB] text-white font-bold text-lg uppercase tracking-widest hover:bg-[#0047AB]/20 transition-all">
          Descargar Reglamento
        </a>
      </div>
    </div>
  </section>

  <!-- Facebook Live Section -->
  <section class="py-20 bg-black/50 relative border-y border-[#39ff14]/20">
    <div class="container mx-auto px-4">
      <div class="flex items-center gap-4 mb-10 justify-center">
        <span class="w-3 h-3 rounded-full bg-[#ffea00] animate-ping"></span>
        <h2 class="text-4xl font-black text-center text-white uppercase tracking-widest">
          Transmisión en <span class="text-[#ffea00]">Vivo</span>
        </h2>
      </div>
      
      <div class="max-w-4xl mx-auto aspect-video bg-[#1a1a1a] border border-[#0047AB]/30 shadow-[0_0_30px_rgba(0,71,171,0.2)] flex items-center justify-center relative group overflow-hidden">
        <!-- Placeholder for Facebook iframe -->
        <div class="text-center p-8 relative z-10">
          <svg class="w-16 h-16 mx-auto text-[#0047AB] mb-4 opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          <p class="text-gray-400 font-bold uppercase tracking-widest">El streaming comenzará pronto</p>
          <p class="text-sm text-gray-600 mt-2">Aquí se incrustará el iframe de Facebook Live</p>
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#0047AB]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </div>
    </div>
  </section>

  <!-- Merch Slider Placeholder Section -->
  <section class="py-24">
    <div class="container mx-auto px-4">
      <h2 class="text-5xl font-black text-center text-white uppercase tracking-widest mb-16 drop-shadow-[0_0_10px_rgba(57,255,20,0.3)]">
        Merch <span class="text-[#39ff14]">Oficial</span>
      </h2>
      
      <div class="flex overflow-x-auto gap-8 pb-8 snap-x snap-mandatory hide-scrollbar">
        {merchItems.map(item => (
          <div class="snap-center shrink-0 w-[300px] bg-[#111] border border-gray-800 p-6 group hover:border-[#39ff14]/50 transition-colors rounded">
            <div class="aspect-square bg-[#0a0a0a] border border-[#0047AB]/30 mb-6 flex items-center justify-center overflow-hidden relative group-hover:border-[#39ff14] transition-colors rounded">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover absolute inset-0 group-hover:scale-110 transition-transform duration-500" />
            </div>
            <h3 class="font-bold text-xl mb-3 text-white group-hover:text-[#39ff14] transition-colors leading-tight">{item.name}</h3>
            <p class="text-[#39ff14] font-black text-2xl tracking-wider">{item.price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
