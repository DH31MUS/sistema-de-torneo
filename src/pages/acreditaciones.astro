---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
---
<Layout title="Acreditaciones">
  <section class="py-24 min-h-[80vh] flex flex-col items-center justify-center relative">
    <div class="absolute inset-0 bg-[url('/img/grid.svg')] opacity-10 bg-center"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-5xl md:text-7xl font-black mb-12 uppercase tracking-widest">
        Nuestras <span class="text-[#ffea00]">Acreditaciones</span>
      </h1>
      
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        {siteConfig.acreditaciones.map(acc => (
          <a href={acc.url} target="_blank" class="p-6 bg-[#1a1a1a] border border-[#6a0dad]/30 hover:border-[#39ff14] transition-all group flex items-center justify-between shadow-[0_0_10px_rgba(0,0,0,0.5)] hover:shadow-[0_0_20px_rgba(57,255,20,0.2)] rounded">
            <div class="flex items-center gap-4">
              {acc.image ? (
                <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-[#9d4edd] group-hover:border-[#39ff14] transition-colors flex-shrink-0 bg-white flex items-center justify-center">
                  <img src={acc.image} alt={acc.name} class="w-full h-full object-cover" />
                </div>
              ) : (
                <div class="w-16 h-16 rounded-full border-2 border-[#9d4edd] group-hover:border-[#39ff14] transition-colors flex-shrink-0 bg-[#0a0a0a] flex items-center justify-center">
                  <span class="text-[#39ff14] font-black">{acc.name.charAt(0)}</span>
                </div>
              )}
              <span class="text-xl font-bold group-hover:text-[#39ff14] transition-colors">{acc.name}</span>
            </div>
            <svg class="w-6 h-6 text-[#9d4edd] group-hover:text-[#39ff14] transition-colors flex-shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
